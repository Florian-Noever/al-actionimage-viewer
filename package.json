{
  "name": "al-actionimage-viewer",
  "displayName": "AL ActionImage Viewer",
  "description": "View, Search and Copy AL Action Images",
  "version": "0.2.0",
  "publisher": "Florian-Noever",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Florian-Noever/al-actionimage-viewer"
  },
  "bugs": {
    "url": "https://github.com/Florian-Noever/al-actionimage-viewer/issues"
  },
  "homepage": "https://github.com/Florian-Noever/al-actionimage-viewer",
  "keywords": [
    "AL",
    "Business Central",
    "Dynamics 365",
    "ActionImage",
    "Actions",
    "Icons",
    "Viewer",
    "AL Language"
  ],
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "extensionDependencies": [
    "ms-dynamics-smb.al"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "al-actionimage-viewer.open",
        "title": "AL ActionImage Viewer"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "vite build",
    "dev:webview": "vite",
    "lint": "eslint src",
    "package": "npx -y @vscode/vsce package",
    "test": "npm run compile && node ./out/test/runTests.js"
  },
  "devDependencies": {
    "@tanstack/vue-virtual": "^3.13.19",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@vscode/test-electron": "^2.4.1",
    "mocha": "^11.1.0",
    "@types/vscode": "^1.105.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue": "^3.5.29"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "floating-vue": "^5.2.2"
  }
}